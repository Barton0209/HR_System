# ============================================================
# HR System v2.0 — переменные окружения
# Скопируйте в .env и заполните реальными значениями
# ============================================================

# --- CORS Origins (через запятую) ---
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Database ---
DATABASE_URL=sqlite:///data/hr_system.db

# --- OCR Settings ---
OCR_DEFAULT_MODEL=PaddleOCR-VL-0.9B
OCR_GPU_ENABLED=false

# --- Admin Password (измените на свой!) ---
ADMIN_PASSWORD=CHANGE_ME_PLEASE_123

# --- API Keys (если используется внешний OCR) ---
# DEEPSEEK_API_KEY=your_key_here
